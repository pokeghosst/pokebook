{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PokeBook",
  "version": "3.3.0-rc+w.1",
  "identifier": "org.pokeghost.book",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run static"
  },
  "app": {
    "windows": [
      {
        "title": "PokeBook",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
